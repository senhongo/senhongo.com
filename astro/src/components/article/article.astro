---
import { type CollectionEntry } from 'astro:content';

import Pill from '@/components/taxonomy/pill.astro';
import PillList from '@/components/taxonomy/pill-list.astro';

import styles from './article.module.scss';

type Props = CollectionEntry<'blog'>['data'];

const { date, updatedDate, category, series, tags } = Astro.props;
---

<div class={styles.metadata}>
  <section>
    <p>published: {date}</p>
    {updatedDate && <p>updated: {updatedDate}</p>}
  </section>

  <section class={styles.taxonomy}>
    {
      category && (
        <section>
          <span>
            category: <Pill type="categories" value={category} />
          </span>
        </section>
      )
    }

    {
      series && (
        <section>
          <span>
            part of series: <Pill type="series" value={series} />
          </span>
        </section>
      )
    }

    {
      tags.length > 0 && (
        <PillList>
          {tags.map((tag) => (
            <Pill value={tag} type="tags" />
          ))}
        </PillList>
      )
    }
  </section>
</div>

<article class={styles.contents}>
  <slot />
</article>
