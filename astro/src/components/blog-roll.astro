---
import type { CollectionEntry } from 'astro:content';

import Tags from '@/components//taxonomy/tags.astro';
import Category from '@/components//taxonomy/category.astro';
import Series from '@/components//taxonomy/series.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{
  posts.map((a) => (
    <article class="blog-roll">
      <span class="blog-roll--date">{a.data.date}</span>

      <header class="blog-roll--header">
        <h2>
          <a class="blog-roll--title" href={`/blog/${a.id}`}>
            {a.data.title}
          </a>
        </h2>
        <Category value={a.data.category} />
      </header>

      <section class="blog-roll--tags">
        <Series value={a.data.series} />
        <Tags values={a.data.tags} />
      </section>
    </article>
  ))
}
