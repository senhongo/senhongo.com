---
import type { CollectionEntry } from "astro:content";
import Category from '@/components//taxonomy/category.astro';

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

{
  posts.map((a) => (
    <article class="blog-roll">
      <span class="blog-roll--date">{a.data.date}</span>

      <h2>
        <a class="blog-roll--title" href={`/blog/${a.id}`}>
          {a.data.title}
        </a>
      </h2>
        {/* {a.data.tags && a.data.tags.length > 0 && a.data.tags.map((t) => <span>{t}</span>)} */}

      <Category value={a.data.category} />
    </article>
  ))
}
