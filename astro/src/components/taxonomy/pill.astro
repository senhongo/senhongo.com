---
import classnames from 'classnames';
import styles from './taxonomy.module.scss';

interface Props {
  value: string;
  type: 'tags' | 'categories' | 'series';
  className?: string;
}

const { value, type, className } = Astro.props;
---

<a
  class={classnames(styles.pill, className, styles[type])}
  href={`/${type}/${value}`}
>
  {value}
</a>
