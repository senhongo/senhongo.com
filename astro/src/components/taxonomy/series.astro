---
import { getCollection } from 'astro:content';

import PillList from './pill-list.astro';
import Pill from './pill.astro';

const allPosts = await getCollection('blog');
const series = [
  ...new Set(
    allPosts
      .filter((post) => post.data.series)
      .sort((a, b) =>
        b.data.date.localeCompare(a.data.date, undefined, { numeric: true }),
      )
      .flatMap((post) => post.data.series),
  ),
];
---

{
  series.length > 0 && (
    <PillList>
      {series.map((serie) => (
        <Pill value={serie} type="series" />
      ))}
    </PillList>
  )
}
