        <button>food</button>
        <button>asdf</button>
    </div>

    <div>
        <details>
          <summary>Series</summary>
          <ui>
            <li>thoughts</li>
            <li>dev</li>
            <li>blah</li>
            <li>food</li>
            <li>asdf</li>
          </ui>
        </details>
    </div>
  </div>
  <BlogRoll posts={posts} />
</Layout>
