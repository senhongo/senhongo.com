---
import { getCollection } from 'astro:content';

import Taxonomy from '@/components/taxonomy/taxonomy.astro';
import Layout from '@/components/layouts/default.astro';
import BlogRoll from '@/components/blog-roll/blog-roll.astro';

const posts = (await getCollection('blog')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date, undefined, { numeric: true }),
);
---

<Layout title={`all articles (${posts.length})`}>
  <Taxonomy />

  <BlogRoll posts={posts} />
</Layout>
