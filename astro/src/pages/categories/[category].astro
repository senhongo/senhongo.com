---
import { getCollection } from 'astro:content';

import Layout from '@/components/layouts/default.astro';
import BlogRoll from '@/components/blog-roll/blog-roll.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const allCategories = [
    ...new Set(allPosts.flatMap((post) => post.data.category)),
  ];

  return allCategories.map((category) => ({
    params: { category },
    props: {
      posts: allPosts
        .filter((post) => post.data.category === category)
        .sort((a, b) =>
          b.data.date.localeCompare(a.data.date, undefined, { numeric: true }),
        ),
    },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`${category} category`}>
  <BlogRoll posts={posts} />
</Layout>
