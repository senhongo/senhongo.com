---
import Layout from '@/components/layouts/default.astro';

import { getCollection } from 'astro:content';

import { Content } from '@/__content/pages/cpta.md';

const allBlogPosts = (await getCollection('blog'))
  .filter((post) => post.data.series === 'CPTA')
  .sort((a, b) =>
    a.data.date.localeCompare(b.data.date, undefined, { numeric: true }),
  );

const posts = allBlogPosts.filter(
  (note) => note.data.category !== 'study notes',
);
const studyNotes = allBlogPosts.filter(
  (note) => note.data.category === 'study notes',
);
---

<Layout title="Becoming a Certified Public Tax Accountant in Japan">
  <Content />

  <section>
    <h2>Glossary</h2>

    <p>blah blah</p>
  </section>

  <p>tag cloud</p>

  <div class="grid-auto-fill">
    <div>
      <h3>Posts ({posts.length})</h3>
      {posts.map((post) => <p>{post.data.title}</p>)}
    </div>

    <div>
      <h3>Study Notes ({studyNotes.length})</h3>
      {studyNotes.map((post) => <p>{post.data.title}</p>)}
    </div>
  </div>
</Layout>
