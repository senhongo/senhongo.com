---
import { getCollection } from 'astro:content';

import Layout from '@/components/layouts/default.astro';
import BlogRoll from '@/components/blog-roll/blog-roll.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const tags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) =>
          b.data.date.localeCompare(a.data.date, undefined, { numeric: true }),
        ),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`articles tagged ${tag}`}>
  <BlogRoll posts={posts} />
</Layout>
